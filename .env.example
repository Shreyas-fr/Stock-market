# ════════════════════════════════════════════════════════════════
# Supply Chain Intelligence Platform — Environment Configuration
# ════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Application ─────────────────────────────────────────────
APP_NAME="Supply Chain Intelligence Platform"
APP_ENV=development                  # development | staging | production
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── PostgreSQL ──────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sci_db
POSTGRES_USER=sci_user
POSTGRES_PASSWORD=sci_password
DATABASE_URL=postgresql+asyncpg://sci_user:sci_password@localhost:5432/sci_db
DATABASE_URL_SYNC=postgresql://sci_user:sci_password@localhost:5432/sci_db

# ─── Neo4j ───────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sci_password

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=sci_password
REDIS_URL=redis://:sci_password@localhost:6379/0
CELERY_BROKER_URL=redis://:sci_password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:sci_password@localhost:6379/2

# ─── Elasticsearch ───────────────────────────────────────────
ELASTICSEARCH_URL=http://elastic:sci_password@localhost:9200
ELASTIC_PASSWORD=sci_password

# ─── AI / LLM APIs ───────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ─── Financial Data APIs ─────────────────────────────────────
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
FMP_API_KEY=your-financial-modeling-prep-key
POLYGON_API_KEY=your-polygon-io-key
YAHOO_FINANCE_ENABLED=true

# ─── News APIs ───────────────────────────────────────────────
NEWSAPI_KEY=your-newsapi-key
GNEWS_API_KEY=your-gnews-key

# ─── Vector Database ─────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-key
PINECONE_ENV=us-east-1-aws
PINECONE_INDEX=sci-embeddings

# Use Qdrant (local/free alternative to Pinecone)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=sci-embeddings
USE_LOCAL_VECTOR_DB=true           # true = Qdrant, false = Pinecone

# ─── JWT Auth ────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Email (Alerts) ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@sci-platform.com

# ─── Slack (Alerts) ──────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=100

# ─── Caching ─────────────────────────────────────────────────
CACHE_TTL_PRICES=30                 # seconds
CACHE_TTL_COMPANY=3600              # 1 hour
CACHE_TTL_RISK_SCORE=3600           # 1 hour
CACHE_TTL_NEWS=300                  # 5 minutes
CACHE_TTL_POLICIES=1800             # 30 minutes
CACHE_TTL_GRAPH=7200                # 2 hours

# ─── Ingestion Schedule ──────────────────────────────────────
PRICE_UPDATE_INTERVAL_SECONDS=60
NEWS_UPDATE_INTERVAL_SECONDS=300
POLICY_UPDATE_INTERVAL_SECONDS=900
RISK_RECALC_INTERVAL_SECONDS=1800

# ─── Monitoring ──────────────────────────────────────────────
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=INFO
